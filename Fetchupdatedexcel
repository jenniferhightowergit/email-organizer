def attach_excel_match_flag(
    df_main: pd.DataFrame,
    df_lookup: pd.DataFrame,
    location_col: str,
    meter_col: str,
    lookup_location_col: str = None,
    lookup_meter_col: str = None
) -> pd.DataFrame:
    
    df_main = df_main.copy()
    df_lookup = df_lookup.copy()
    
    # Default to same column names if not provided
    lookup_location_col = lookup_location_col or location_col
    lookup_meter_col = lookup_meter_col or meter_col
    
    # Clean columns
    df_main[location_col] = df_main[location_col].astype(str).str.strip()
    df_main[meter_col] = df_main[meter_col].astype(str).str.strip()
    
    df_lookup[lookup_location_col] = df_lookup[lookup_location_col].astype(str).str.strip()
    df_lookup[lookup_meter_col] = df_lookup[lookup_meter_col].astype(str).str.strip()
    
    df_result = df_main.merge(
        df_lookup.assign(in_excel_file=1),
        how="left",
        left_on=[location_col, meter_col],
        right_on=[lookup_location_col, lookup_meter_col]
    )
    
    df_result["in_excel_file"] = df_result["in_excel_file"].fillna(0).astype(int)
    
    return df_result


