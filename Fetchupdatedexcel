def attach_excel_match_flags(
    df_main: pd.DataFrame,
    df_lookup: pd.DataFrame,
    main_location_col: str,
    main_meter_col: str,
    lookup_location_col: str = None,
    lookup_meter_col: str = None
) -> pd.DataFrame:
    
    df_main = df_main.copy()
    df_lookup = df_lookup.copy()
    
    lookup_location_col = lookup_location_col or main_location_col
    lookup_meter_col = lookup_meter_col or main_meter_col

    # Clean main df
    df_main[main_location_col] = df_main[main_location_col].astype(str).str.strip()
    df_main[main_meter_col] = df_main[main_meter_col].astype(str).str.strip()

    # Clean lookup df
    df_lookup[lookup_location_col] = df_lookup[lookup_location_col].astype(str).str.strip()
    df_lookup[lookup_meter_col] = df_lookup[lookup_meter_col].astype(str).str.strip()

    # Separate match flags
    df_main["location_match_flag"] = (
        df_main[main_location_col]
        .isin(df_lookup[lookup_location_col].dropna().unique())
        .astype(int)
    )

    df_main["meter_match_flag"] = (
        df_main[main_meter_col]
        .isin(df_lookup[lookup_meter_col].dropna().unique())
        .astype(int)
    )

    return df_main


df_joined = attach_excel_match_flags(
    df_main=df_main,
    df_lookup=df_lookup,
    main_location_col="location_id",
    main_meter_col="meter_number",
    lookup_location_col="Location ID",
    lookup_meter_col="Meter Num"
)
