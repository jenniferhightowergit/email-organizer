import glob
import os
from datetime import datetime

# Config
path = r"mypath\*.xlsx"  # Update this to your actual path with wildcard
start_date = datetime(2026, 1, 1)
end_date = datetime.today()

# Get all xlsx files, exclude temp files starting with ~$
files = glob.glob(path)
files = [f for f in files if not os.path.basename(f).startswith("~$")]

# Apply date filter based on file modified date
files = [
    f for f in files
    if start_date <= datetime.fromtimestamp(os.path.getmtime(f)) <= end_date
]

# Results
print(f"Found {len(files)} file(s) modified between {start_date.date()} and {end_date.date()}:\n")
for f in files:
    mod_time = datetime.fromtimestamp(os.path.getmtime(f))
    print(f"  {os.path.basename(f)}  —  Modified: {mod_time.strftime('%Y-%m-%d %H:%M')}")



